# --- JetBrains (IntelliJ IDEA) 相关配置 ---
# 忽略项目配置文件夹
.idea/
# 忽略模块描述文件
*.iml
# 忽略编译输出文件夹
out/
build/

# --- VS Code 相关配置 ---
# 忽略本地工作区设置（建议保留，除非团队强制统一格式）
.vscode/
# 忽略工作区文件
*.code-workspace
# 忽略历史记录
.history/

# --- 常见语言编译/运行产物 (针对算法刷题) ---

# Java
*.class
*.log
*.jar
*.war

# C/C++
*.exe
*.o
*.obj
*.dll
*.dylib
*.so
# Mac下常见的调试文件夹
*.dSYM/

# Python (如果你用 Python 刷题)
__pycache__/
*.py[cod]

# Node/JS (如果你用 JS/TS 刷题)
node_modules/
dist/

# --- 操作系统生成的文件 ---
.DS_Store
Thumbs.db